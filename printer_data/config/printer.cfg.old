[include mainsail.cfg]
[mcu]
#serial: /dev/serial/by-id/usb-1a86_USB2.0-Serial-if00-port0[mcu]

serial: /dev/serial/by-path/platform-1c1b400.usb-usb-0:1:1.0-port0



#restart_method: command
baud: 250000
# Option A: Try adding this line if your board hangs on restart
restart_method: arduino

[axis_twist_compensation]
 speed: 50
#   The speed (in mm/s) of non-probing moves during calibration.
#   The default is 50.
 horizontal_move_z: 5
#   The distance (in mm) that the Z axis is lifted above the bed before
#   a probing move. The default is 5.

# --- X-AXIS CALIBRATION PATH ---
calibrate_start_x: 25
#   Safely clear of the front-left and back-left corner clips.
calibrate_end_x: 225
#   Safely stops before hitting the front-right and back-right corner clips
calibrate_x: 129 # 127 seems not dead centre
#   The absolute center of your X

# --- Y-AXIS CALIBRATION PATH ---
calibrate_start_y: 25
#   Safely clear of the front-left and front-right corner clips.
calibrate_y: 127 
#   The absolute center of your Y-axis (255 / 2), avoiding the side clips completely.
calibrate_end_y: 220
#   Safely stops before hitting the back-left and back-right corner clips.
#-axis (255 / 2), keeping the toolhead centered.





[virtual_sdcard]
path: /home/ben/printer_data/gcodes
on_error_gcode: CANCEL_PRINT

# This file contains common pin mappings for Ultimaker UltiMainboard v2
# boards. To use this config, the firmware should be compiled for the
# AVR atmega2560.

# See docs/Config_Reference.md for a description of parameters.
# [include fluidd.cfg]

### Include macros
[include macros/cancel.cfg]
[include macros/start_print.cfg]
[include macros/end_print.cfg]
[include macros/bltouch.cfg]
[include macros/pause_print.cfg]
[include macros/clean_nozzle.cfg]
[include macros/load_filament.cfg]
[include macros/unload_filament.cfg]
[include macros/PARK_AND_SLEEP.cfg]
[include macros/WAKE_AND_RESUME.cfg]
[include macros/bed_heat_55.cfg]



# Pi as MCU
#[mcu pi]
#serial: /tmp/klipper_host_mcu

# --- X / Y / Z Steppers ---

[stepper_x]
step_pin: PC0
dir_pin: !PG2
enable_pin: !PC2
microsteps: 16
rotation_distance: 40 #39.851  # Converted from Marlin 80.3
#endstop_pin: ^!PD2
endstop_pin:  !PK5   # using fillament sensor
position_min: -30
position_endstop:-10
position_max: 270
homing_speed: 80.0


[stepper_y]
step_pin: PC6
dir_pin: PC4
enable_pin: !PA7
microsteps: 16
rotation_distance: 40
#endstop_pin: ^PA4 
endstop_pin: !PK4 #using filament sensor
position_min: -30
position_endstop: -5
position_max: 270
homing_speed: 50




[stepper_z] ####note using extruder 2 slot as original z fucked
step_pin: PL6  ###using dfisplay pin
dir_pin: !PL4
enable_pin: !PG0  ####needed inverting doh !!!
microsteps: 16
rotation_distance: 8.000   # Converted from Marlin 400.0
position_min: -1
endstop_pin: probe:z_virtual_endstop
position_max: 230
homing_speed: 10.0
homing_retract_dist: 5.0




# --- Extruders (Mix Color Setup) ---

# Extruder 0 (Marlin E1)
[extruder]
step_pin: PL3
dir_pin: PL5
enable_pin: !PB6
microsteps: 16
rotation_distance: 7.739 #7.754 # 7.725 #7.529 old calculated by gemini from Marlin 425.0
nozzle_diameter: 0.400
filament_diameter: 1.750
heater_pin: PB4
sensor_pin: PK3
#sensor_type: ATC Semitec 104GT-2
sensor_type: EPCOS 100K B57560G104F
#sensor_type: Generic 3950   #this ONE <-----------
min_temp: 0
max_temp: 260
max_extrude_cross_section: 5.0
max_extrude_only_velocity: 45
max_extrude_only_accel: 1200     # <-- Add this to smooth out the acceleration ramp
pressure_advance: 0.75 # 0.44 #0.43    # <-- Type your winning number here 0.045  SET TO 0 FOR TESTING
pressure_advance_smooth_time: 0.06 # was 0.04 higher to smmoth out extruder noise
max_extrude_only_distance: 350.0
[firmware_retraction]
retract_length: 1.4 # 1.8 #2      ; Your quiet direct-drive length (use 4.0 if Bowden)  2mm@20mm/s 3mm@30mm/s 4mm@40 mm/s
retract_speed: 25           ; Your tuned safe, quiet speed
#unretract_extra_length: 0.2   ; No extra push needed
unretract_speed: 20         ; Matching prime speed




# Extruder 1 (Marlin E2)
[extruder_stepper extruder1]
extruder: extruder
step_pin: PL0
dir_pin: !PL2
enable_pin: !PL1
microsteps: 16
rotation_distance: 4.341   # Converted from Marlin 737.1 (voron design belt extruder)

# --- Mixing Extruder Control Macros ---

[gcode_macro T0]
gcode:
    SET_GCODE_OFFSET X=0 Y=0 Z=0
    SYNC_EXTRUDER_MOTION EXTRUDER=extruder1 MOTION_QUEUE=
    SYNC_EXTRUDER_MOTION EXTRUDER=extruder MOTION_QUEUE=extruder

[gcode_macro T1]
gcode:
    SET_GCODE_OFFSET X=0 Y=0 Z=0
    SYNC_EXTRUDER_MOTION EXTRUDER=extruder MOTION_QUEUE=
    SYNC_EXTRUDER_MOTION EXTRUDER=extruder1 MOTION_QUEUE=extruder

[gcode_macro ACTIVATE_EXTRUDER]
description: Replaces built-in macro for a X-in, 1-out extruder configuration SuperSlicer fix
rename_existing: ACTIVATE_EXTRUDER_BASE
gcode:
    {% if 'EXTRUDER' in params %}
      {% set ext = params.EXTRUDER|default(EXTRUDER) %}
      {% if ext == "extruder"%}
        {action_respond_info("Switching to extruder0.")}
        T0
      {% elif ext == "extruder1" %}
        {action_respond_info("Switching to extruder1.")}
        T1
      {% else %}
        {action_respond_info("EXTRUDER value being passed.")}
        ACTIVATE_EXTRUDER_BASE EXTRUDER={ext}
      {% endif %}
    {% endif %}

# --- Heatbed ---

[heater_bed]
heater_pin: PG5
#sensor_type: Generic 3950
sensor_type: EPCOS 100K B57560G104F
sensor_pin: PK2
#control = pid
#pid_kp = 64.568
#pid_ki = 2.446
#pid_kd = 426.149
#control: pid   
#pid_Kp: 68.45
#pid_Ki: 1.35
#pid_Kd: 865.20
min_temp: 0
max_temp: 115

# --- Fans ---

[fan]
pin: PH6


[printer]
kinematics: cartesian
max_velocity: 300
max_accel: 3000
max_z_velocity: 50
max_z_accel: 500
minimum_cruise_ratio: 0.5  ###SET TO 0.5 AFTER TESTING
square_corner_velocity: 5    ### DONT KNOW FIGURE YET TESTING




# --- BLTouch & Probing Zones ---
[bltouch]
sensor_pin: ^PC7
control_pin: PB5
pin_move_time: 0.680
x_offset: -37
y_offset: 2
#z_offset: 2.32 #2.295 ### WAS @ 2.235
samples: 3 # trying 2 instead of 3 bc its quicker 
samples_result: median
samples_tolerance: 0.05
samples_tolerance_retries: 3
sample_retract_dist: 5
# speed: 10 ### trying speed bellow for better results 
pin_up_reports_not_triggered: False
pin_up_touch_mode_reports_triggered: False
probe_with_touch_mode: False

speed: 30           # WAS 5.0 This is the "fast" travel speed between points
lift_speed: 10         #  WAS 10
#samples_speed: 2.0

#speed: 5.0              # This is the "fast" travel speed between points
#lift_speed: 10          # Speed at which the probe lifts before moving
#samples_speed: 2.0      # This is the "slow" precision for the actual trigger



[safe_z_home]
# left front corner screw
home_xy_position: 82, 44
speed: 50
z_hop: 5
z_hop_speed: 5

[bed_mesh]
speed: 50
horizontal_move_z: 5
# Safe limits for physical BLTouch Pin landing on PEI sheet away from clips
mesh_min: 50,50 #35, 35      moved bc clips messing up mesh
mesh_max: 195, 215   #218, 238 for near max, but clips and shit throw results way off so using smaller bed mesh
probe_count: 4, 4 ### set back to 7,7 just running diagnostics
mesh_pps: 2, 2
algorithm: bicubic
bicubic_tension: 0.2
move_check_distance: 5
split_delta_z: 0.05 # originally 0.025 but to finr for z axis adjustment 
#zero_reference_position: 87, 52
fade_start: 1.0
fade_end: 10.0
fade_target: 0





[bed_screws]
screw1: 92, 52
screw2: 92, 217
screw3: 213, 52
screw4: 213, 217

[screws_tilt_adjust]
# Nozzle positions adjusted so the probe pin lands exactly over bed screws
screw1: 82, 44
screw1_name: front left screw
screw2: 252, 44
screw2_name: front right screw
screw3: 252, 212
screw3_name: rear right screw
screw4: 82, 212
screw4_name: rear left screw
horizontal_move_z: 10.
speed: 50.
screw_thread: CW-M3



# --- Display (GT2560 Layout) ---
# # for GT2560V4.0 12pin flat cable
[display]
lcd_type: st7920
cs_pin: PE3
sclk_pin: PD0
sid_pin: PC1
encoder_pins: ^PH0, ^PH1
click_pin: ^!PD2

# # for GT2560V4.1B with 12pin flat cable toward the display YHCB2004-06 ver3.0
# # the aip31068_spi driver was added to Klipper on 2024-12-02, commit aecb29d2
# [display]
# lcd_type: aip31068_spi
# latch_pin: PE3
# spi_software_sclk_pin: PD0
# spi_software_mosi_pin: PC1
# spi_software_miso_pin: PH7 # any unused pin
# encoder_pins: ^PH0, ^PH1
# click_pin: ^!PD2

[output_pin BEEPER_pin]
pin: PD3
pwm: True
value: 0
shutdown_value: 0
cycle_time: 0.001
scale: 1000

[endstop_phase]

[input_shaper]
shaper_freq_x= 38.81    # OFF FOR TESTING
shaper_freq_y= 60      #
shaper_type: 2hump_ei



[pause_resume]

[display_status]

# [filament_switch_sensor e0_sensor] # using them as endstops
# pause_on_runout: True
# switch_pin: PK4

# [filament_switch_sensor e1_sensor] ## being used for x,y endstops
# pause_on_runout: True
# switch_pin: PK5

[temperature_sensor OrangePi_Zero]
sensor_type: temperature_host
# sensor_path: /sys/class/thermal/thermal_zone1/temp

[exclude_object]


[include KAMP_Settings.cfg]
# to enable M118 echo command
[respond]

# Specific macros for mixing colors.
# Add in slicer new filament color and in filament start G-Code add desired mixing factor:
#     M163 S0 P50 ; set extruder 0 to 50%
#     M163 S1 P40 ; set extruder 1 to 40%
#     M163 S2 P10 ; set extruder 2 to 10%
#     M164 ; commit the mix factors
[gcode_macro M163]
description:  M163 [P<factor>] [S<index>] Set a single mix factor (in proportion to the sum total of all mix factors). The mix must be committed to a virtual tool by M164 before it takes effect.
gcode:
    {% if 'P' in params %}
            {% set s = params.S|default(0)| int %}
            {% if s == 0 %}
                SET_GCODE_VARIABLE MACRO=M164 VARIABLE=e0_parts VALUE={params.P|default(0)|float}
                M118 Set Mixing factor for extruder 0 to {params.P|default(0)|float}
            {% elif s == 1 %}
                SET_GCODE_VARIABLE MACRO=M164 VARIABLE=e1_parts VALUE={params.P|default(0)|float}
                M118 Set Mixing factor for extruder 1 to {params.P|default(0)|float}
            {% elif s == 2 %}
                SET_GCODE_VARIABLE MACRO=M164 VARIABLE=e2_parts VALUE={params.P|default(0)|float}
                M118 Set Mixing factor for extruder 2 to {params.P|default(0)|float}
            {% endif %}
    {% else %}
        M118 No Mixing factor set, missing value for P
    {% endif %}
    M118 {e0_parts} {e1_parts} {e2_parts}


[gcode_macro M164]
description: Applies the set mixing factors to the extruders
# default values:
variable_e0_parts : 100
variable_e1_parts : 0
variable_e2_parts : 0
gcode:
    # normalize the parts to sum of 1
    {% set e0 = e0_parts / (e0_parts + e1_parts + e2_parts) | float %}
    {% set e1 = e1_parts / (e0_parts + e1_parts + e2_parts) | float %}
    {% set e2 = e2_parts / (e0_parts + e1_parts + e2_parts) | float %}
    M118 scaled rot-dist_e0 { printer.configfile.settings.extruder.rotation_distance / (e0 + 0.000001) | float }
    M118 scaled rot-dist_e1 { printer.configfile.settings['extruder_stepper extruder_1'].rotation_distance / (e1 + 0.000001) | float }
    M118 scaled rot-dist_e2 { printer.configfile.settings['extruder_stepper extruder_2'].rotation_distance / (e2 + 0.000001) |float }
    # activate stepper percentages
    SYNC_EXTRUDER_MOTION EXTRUDER=extruder MOTION_QUEUE=extruder
    SYNC_EXTRUDER_MOTION EXTRUDER=extruder_1 MOTION_QUEUE=extruder
    SYNC_EXTRUDER_MOTION EXTRUDER=extruder_2 MOTION_QUEUE=extruder
    SET_EXTRUDER_ROTATION_DISTANCE EXTRUDER=extruder DISTANCE={ printer.configfile.settings.extruder.rotation_distance / (e0+0.000001)|float }
    SET_EXTRUDER_ROTATION_DISTANCE EXTRUDER=extruder_1 DISTANCE={ printer.configfile.settings['extruder_stepper extruder_1'].rotation_distance / (e1+0.000001)|float }
    SET_EXTRUDER_ROTATION_DISTANCE EXTRUDER=extruder_2 DISTANCE={ printer.configfile.settings['extruder_stepper extruder_2'].rotation_distance / (e2+0.000001)|float }
    M118 Mixing factors {e0} {e1} {e2} are activated

# In PrusaSlicer:
#    - you can add as many extruders as mixing ratios you want
#    - in Printer Settings -> Custom G-code -> Tool change G-code add:
#        TOOL_CHANGE EXTRUDER={next_extruder}
#    - in this config file add:
#           [gcode_macro TOOL_CHANGE]
#           description: Tool change macro with mix ratio setup for 11 extruders
#           variable_extruder: 0
#           gcode:
#               {% set extruder = params.EXTRUDER|default(0)| int %}
#               {% if extruder == 0 %}
#                   M163 S0 P100
#                   M163 S1 P0
#                   M163 S2 P0
#                   M164
#                   M118 Switching to Extruder 0
#               {% elif extruder == 1 %}
#                   M163 S0 P90
#                   M163 S1 P10
#                   M163 S2P0
#                   M164
#                   M118 Switching to Extruder 1
#               {% elif extruder == 2 %}
#                   # and so on ...
#               {% else %}
#                   M118 Unknown extruder number: {extruder}
#               {% endif %}

# In OrcaSlicer:
# you can add as many filaments as mixing ratios you want
# in Material settings -> Advanced -> Filament start G-code add desired mixing ratio:
#    ; filament start gcode
#    M163 S0 P100 ; set extruder 0
#    M163 S1 P0 ; set extruder 1
#    M163 S2 P0 ; set extruder 2
#    M164 ; commit the mix factors

# For gradient over Z axis:
# In `Printer -> Custom G-code -> After layer change G-code` add:
#     M163 S0 P{ layer_num * 100 / total_layer_count } ; Gradient 0-100
#     M163 S1 P{(total_layer_count-layer_num) * 100 / total_layer_count} ; Gradient 100-0
#     M164 ; commit the mix factors

